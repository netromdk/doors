#ifndef UTILITY_H
#define UTILITY_H

#include <volatile.h>

template <typename T1, typename T2>
struct pair {
  T1 first;
  T2 second;

  pair() = default;

  constexpr pair(T1 a, T2 b) : first(a), second(b)
  {
  }
};

template <typename T, typename U = T>
constexpr remove_volatile_t<T> exchange(T &obj, U new_value) noexcept
{
  auto old = static_cast<remove_volatile_t<T>>(obj);
  obj = static_cast<T>(new_value);
  return old;
}

#endif // UTILITY_H
