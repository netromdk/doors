{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "description": "i386-elf cross-compiled kernel, no serial debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "toolchainFile": "${sourceDir}/cmake/i386-elf-toolchain.cmake",
      "cacheVariables": {
        "SERIAL_DEBUG": "OFF"
      }
    },
    {
      "name": "serial-debug",
      "displayName": "Serial Debug",
      "description": "Same as default but mirrors printf to COM1 (captured in doors.log)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/serial-debug",
      "cacheVariables": {
        "SERIAL_DEBUG": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 0
    },
    {
      "name": "serial-debug",
      "inherits": "default",
      "configurePreset": "serial-debug"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "serial-debug",
      "configurePreset": "serial-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
