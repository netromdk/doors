{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "description": "i386-elf cross-compiled kernel, no serial debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "toolchainFile": "${sourceDir}/cmake/i386-elf-toolchain.cmake",
      "cacheVariables": {
        "SERIAL_DEBUG": "OFF"
      }
    },
    {
      "name": "serial-debug",
      "displayName": "Serial Debug",
      "description": "Same as default but mirrors printf to COM1 (captured in doors.log)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/serial-debug",
      "cacheVariables": {
        "SERIAL_DEBUG": "ON"
      }
    },
    {
      "name": "sanitize",
      "displayName": "Sanitize",
      "description": "Default build with ASan + UBSan enabled for host-compiled tests",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/sanitize",
      "cacheVariables": {
        "SANITIZERS": "address;undefined"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized build (-O2, NDEBUG, no serial debug)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "SERIAL_DEBUG": "OFF",
        "DOORS_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "integration-test",
      "displayName": "Integration Test",
      "description": "Builds testrunner.elf and enables serial capture for integration tests",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/integration-test",
      "cacheVariables": {
        "BUILD_INTEGRATION_TESTS": "ON",
        "SERIAL_DEBUG": "ON"
      }
    },
    {
      "name": "analyze",
      "displayName": "Analyze",
      "description": "Static analysis: clang-tidy on host tests and kernel files",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/analyze",
      "cacheVariables": {
        "CLANG_TIDY": "ON",
      }
    },
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 0
    },
    {
      "name": "serial-debug",
      "inherits": "default",
      "configurePreset": "serial-debug"
    },
    {
      "name": "sanitize",
      "inherits": "default",
      "configurePreset": "sanitize"
    },
    {
      "name": "release",
      "inherits": "default",
      "configurePreset": "release"
    },
    {
      "name": "integration-test",
      "inherits": "default",
      "configurePreset": "integration-test"
    },
    {
      "name": "analyze",
      "configurePreset": "analyze",
      "jobs": 0
    },
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "serial-debug",
      "configurePreset": "serial-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "analyze",
      "configurePreset": "analyze",
      "output": { "outputOnFailure": true }
    },
    }
  ]
}
